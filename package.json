{
  "name": "lifes-castle",
  "version": "0.3.31",
  "description": "Life's Castle — focus timer that builds brick walls and castles",
  "main": "expo-router/entry",
  "scripts": {
    "prestart": "node -e \"const v=process.versions.node.split('.').map(Number);if(v[0]<20||(v[0]===20&&v[1]<19)){console.error('\\n❌ Node 20.19+ required (Expo 54). Run: nvm use\\n');process.exit(1)}\"",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:apk:local": "eas build --platform android --profile preview --local",
    "build:apk:gradle": "bash scripts/build-apk-local.sh",
    "install:apk": "bash scripts/install-apk-adb.sh",
    "verify:phone": "bash scripts/verify-phone.sh",
    "extract:building-stages": "bash scripts/extract-building-stages.sh",
    "extract:map": "bash scripts/extract-building-stages.sh",
    "transparentize:buildings": "bash scripts/transparentize-buildings.sh",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.185.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "three": "^0.185.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "eas-cli": "^16.0.0",
    "jest": "^29.7.0",
    "patch-package": "^8.0.1",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "private": true
}
