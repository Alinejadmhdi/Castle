{
  "expo": {
    "name": "Castle",
    "slug": "lifes-castle",
    "version": "0.3.36",
    "orientation": "portrait",
    "scheme": "lifescastle",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1410"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lifescastle.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1410"
      },
      "package": "com.lifescastle.app",
      "label": "Castle",
      "versionCode": 334,
      "permissions": ["VIBRATE"],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcaeec86-2f8a-4616-a965-c1ec4d505dd4"
      }
    },
    "owner": "alinejadmhdi"
  }
}
